{
  "name": "caption-studio",
  "version": "1.0.0",
  "description": "AI-powered video caption generator using Gemini",
  "private": true,
  "scripts": {
    "dev": "concurrently -k -p \"[{name}]\" -n \"SERVER,CLIENT\" -c \"cyan.bold,magenta.bold\" \"node server/index.js\" \"npm run dev --prefix client\"",
    "install:all": "npm install && npm install --prefix client",
    "start": "node server/index.js"
  },
  "dependencies": {
    "@ffmpeg-installer/ffmpeg": "^1.1.0",
    "@ffprobe-installer/ffprobe": "^2.1.2",
    "@google/genai": "^2.10.0",
    "concurrently": "^8.2.2",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "fluent-ffmpeg": "^2.1.3",
    "google-tts-api": "^2.0.2",
    "multer": "^1.4.5-lts.1",
    "node-edge-tts": "^1.2.10",
    "node-fetch": "^2.7.0"
  }
}
